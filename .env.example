# Copy to .env and fill in real values. NEVER commit .env.
# NOTE: EXPO_PUBLIC_* values ship inside the app binary and are extractable —
# free, quota-capped keys only. See docs/plans master plan, "Key-Safety Verdicts".
EXPO_PUBLIC_API_ENV=development
EXPO_PUBLIC_GEODB_API_KEY=
EXPO_PUBLIC_OPENWEATHER_API_KEY=
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=
