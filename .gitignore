# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# release signing (never commit keys or their passwords)
*.keystore
keys/keystore.properties
credentials.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# env secrets (EXPO_PUBLIC_* still ship in the binary - free keys only)
.env

# internal working docs — kept local, not published to the public repo
/CLAUDE.md
/AGENTS.md
/docs/JOURNEY.md
/docs/demo.md
/docs/release.md
/docs/plans/

# local editor/agent config
/.claude/
